<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Redirect root to /rw before Laravel processes
    RewriteRule ^$ /rw [L,R=301]

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# Cache static assets for 1 day
<FilesMatch "\.(json|png|jpg|jpeg|gif|ico|svg|css|js)$">
    Header set Cache-Control "public, max-age=86400"
    Header set Expires "access plus 1 day"
</FilesMatch>

# Cache Lottie animations specifically for 1 day
<FilesMatch "car-moving\.json|bike-moving\.json">
    Header set Cache-Control "public, max-age=86400, must-revalidate"
    Header set Expires "access plus 1 day"
    Header set Last-Modified "Tue, 15 Dec 2024 12:00:00 GMT"
    Header set ETag "\"animation-v1\""
</FilesMatch>
